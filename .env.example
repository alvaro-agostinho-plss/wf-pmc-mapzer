# Autenticação: AUTH_MOCK=true para ignorar SSO e aceitar login direto (desenvolvimento)
# AUTH_MOCK=true
# Opcional: MOCK_USERS=user1:senha1,user2:senha2 para validar credenciais no mock

# PostgreSQL (use DATABASE_URL ou variáveis individuais)
DATABASE_URL=postgres://postgres:senha@host:5432/wfmapzer
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=wfmapzer
# DB_USER=postgres
# DB_PASSWORD=senha

# Diretório de uploads (padrão: uploads/ no projeto)
DIR_UPLOADS=/home/alvaro/uploads/mapzers

# Template de e-mail (padrão: config/email_relatorio.html)
# EMAIL_TEMPLATE=config/email_relatorio.html

# E-mail (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_app
SMTP_FROM=relatorios@prefeitura.gov.br

# E-mail Prefeito/Cópia - relatório mestre com todos os setores (opcional)
EMAIL_PREFEITO=prefeito@prefeitura.gov.br
