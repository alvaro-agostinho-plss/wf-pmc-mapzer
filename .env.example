# Autenticação: AUTH_MOCK=true para ignorar SSO e aceitar login direto (desenvolvimento)
# AUTH_MOCK=true
# Opcional: MOCK_USERS=user1:senha1,user2:senha2 para validar credenciais no mock

# PostgreSQL (use DATABASE_URL ou variáveis individuais)
DATABASE_URL=postgres://postgres:senha@host:5432/wfmapzer
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=wfmapzer
# DB_USER=postgres
# DB_PASSWORD=senha

# Diretório de uploads (padrão: uploads/ no projeto)
DIR_UPLOADS=/home/alvaro/uploads/mapzers

# Origem com https:// (não coloque outro https no código). Opcional: HOST=… se não usar URL_SISTEMA.
URL_SISTEMA=https://portal.castro.pr.gov.br
# Caminho relativo à origem OU URL absoluta (https://…/wfpmcmapzer/rel-ocorrencia)
URL_RELATORIO=/wfpmcmapzer/rel-ocorrencia
# Dias até o link expirar e o HTML ser removido no primeiro acesso após a data (0 = sem expiração)
TOKEN_EXPIRATION_DAYS=30
# Máximo de GET /rel-ocorrencia por IP por minuto (0 = sem limite)
RELATORIO_RATE_LIMIT_PER_MINUTE=40

# Template de e-mail (padrão: config/email_relatorio.html)
# EMAIL_TEMPLATE=config/email_relatorio.html

# E-mail (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_app
SMTP_FROM=relatorios@prefeitura.gov.br

# E-mail Prefeito/Cópia - relatório mestre com todos os setores (opcional)
EMAIL_PREFEITO=prefeito@prefeitura.gov.br

# WhatsApp (API sendText) — geral: WHATSAPP_CHAT_IDS_… | por setor: set_whatsapp no cadastro (mesmo modelo de mensagem)
# WHATSAPP_SERVER_URL=http://172.25.100.151:3001
# WHATSAPP_SERVER_TOKEN=sua_chave_x_api_key
# WHATSAPP_URL_SENDTEXT=/api/sendText
# WHATSAPP_SESSION=default
# WHATSAPP_LINK_PREVIEW=true
# WHATSAPP_CHAT_IDS_RELATORIO_GERAL=5542999461801
# MAPZER_PORTAL_URL=https://portal.castro.pr.gov.br/wfpmcmapzer/login
# URL do relatório detalhado na mensagem WhatsApp (vazio = portal sem /login + /rel-ocorrencia)
# MAPZER_RELATORIO_URL=https://portal.castro.pr.gov.br/wfpmcmapzer/rel-ocorrencia
# MAPZER_RELATORIO_TOKEN=
# Rodapé/assinatura: fixo em config/whatsapp_mensagem_geral.txt e config/whatsapp_mensagem_secretaria.txt
# WHATSAPP_TEMPLATE_GERAL=whatsapp_mensagem_geral.txt
# WHATSAPP_TEMPLATE_SECRETARIA=whatsapp_mensagem_secretaria.txt

# Limites de coordenadas para validação e deduplicação (ETL ocorrências)
LAT_MIN=-25.0700
LAT_MAX=-24.4400
LNG_MIN=-50.2500
LNG_MAX=-49.6100
COORD_PRECISION=6
